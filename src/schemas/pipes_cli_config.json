            "zora-mainnet",
            "zora-sepolia"
          ],
          "description": "Network every template indexes; per-deployment networks may override it in the future."
        },
        "templates": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "templateId": {
                    "type": "string",
                    "const": "custom"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "contracts": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "contractName": {
                              "type": "string",
                              "description": "Contract name (ABI-level identity)"
                            },
                            "contractEvents": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "name": {
                                    "type": "string"
                                  },
                                  "type": {
                                    "type": "string"
                                  },
                                  "inputs": {
                                    "type": "array",
                                    "items": {
                                      "$ref": "#/$defs/__schema0"
                                    }
                                  }
                                },
                                "required": [
                                  "name",
                                  "type",
                                  "inputs"
                                ],
                                "additionalProperties": false
                              },
                              "description": "ABI events to track (shared by all deployments)"
                            },
                            "deployments": {
                              "minItems": 1,
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "address": {
                                    "type": "string",
                                    "description": "Deployed contract address"
                                  },
                                  "range": {
                                    "default": {
                                      "from": "latest"
                                    },
                                    "description": "Block range to index for this deployment",
                                    "type": "object",
                                    "properties": {
                                      "from": {
                                        "type": "string"
                                      },
                                      "to": {
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "from"
                                    ],
                                    "additionalProperties": false
                                  }
                                },
                                "required": [
                                  "address",
                                  "range"
                                ],
                                "additionalProperties": false
                              },
                              "description": "Deployed instances of this contract"
                            }
                          },
                          "required": [
                            "contractName",
                            "contractEvents",
                            "deployments"
                          ],
                          "additionalProperties": false
                        },
                        "description": "Contracts to track: ABI-level identity plus its deployments"
                      }
                    },
                    "required": [
                      "contracts"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "templateId",
                  "params"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "templateId": {
                    "type": "string",
                    "const": "erc20Transfers"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "deployments": {
                        "default": [
                          {
                            "address": "0xc02aaa39b223fe8d0a0e5c4f27ead9083c756cc2",
                            "range": {
                              "from": "12,369,621"
                            }
                          }
                        ],
                        "description": "ERC-20 token deployments to track, each with its own block range",
                        "minItems": 1,
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "address": {
                              "type": "string",
                              "description": "Deployed contract address"
                            },
                            "range": {
                              "default": {
                                "from": "latest"
                              },
                              "description": "Block range to index for this deployment",
                              "type": "object",
                              "properties": {
                                "from": {
                                  "type": "string"
                                },
                                "to": {
                                  "type": "string"
                                }
                              },
                              "required": [
                                "from"
                              ],
                              "additionalProperties": false
                            }
                          },
                          "required": [
                            "address",
                            "range"
                          ],
                          "additionalProperties": false
                        }
                      }
                    },
                    "required": [
                      "deployments"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "templateId",
                  "params"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "templateId": {
                    "type": "string",
                    "const": "uniswapV3Swaps"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "factoryAddress": {
                        "default": "0x1f98431c8ad98523631ae4a59f267346ea31f984",
                        "description": "The Uniswap V3 compatible factory address to dynamically track pools",
                        "type": "string"
                      },
                      "range": {
                        "default": {
                          "from": "12,369,621"
                        },
                        "description": "Block range for indexing",
                        "type": "object",
                        "properties": {
                          "from": {
                            "type": "string"
                          },
                          "to": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "from"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "required": [
                      "factoryAddress",
                      "range"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "templateId",
                  "params"
                ],
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "required": [
        "projectFolder",
        "packageManager",
        "target",
        "networkType",
        "defaultNetwork",
        "templates"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "projectFolder": {
          "type": "string",
          "minLength": 1
        },
        "packageManager": {
          "type": "string",
          "enum": [
            "pnpm",
