{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subsquid Pipes CLI configuration",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "projectFolder": {
          "type": "string",
          "minLength": 1
        },
        "packageManager": {
          "type": "string",
          "enum": [
            "pnpm",
            "yarn",
            "npm",
            "bun"
          ]
        },
        "target": {
          "type": "string",
          "enum": [
            "clickhouse",
            "postgresql"
          ],
          "description": "Storage target for the pipeline data."
        },
        "networkType": {
          "type": "string",
          "const": "evm"
        },
        "defaultNetwork": {
          "type": "string",
          "enum": [
            "0g-testnet",
            "abstract-mainnet",
            "abstract-testnet",
            "agung-evm",
            "aleph-zero-evm-mainnet",
